{
  "name": "@xycloud/pi-cursor",
  "version": "0.1.0",
  "description": "Pi extension that lets Pi use Cursor subscription models through cursor-agent.",
  "type": "module",
  "main": "dist/cursor-acp-extension.js",
  "module": "pi-extension/cursor-acp/index.ts",
  "scripts": {
    "build": "rm -rf ./dist && bun build ./pi-extension/cursor-acp/index.ts --outfile ./dist/cursor-acp-extension.js --target node --external @earendil-works/pi-ai --external @earendil-works/pi-coding-agent",
    "verify": "npm run build && node ./bin/pi-cursor.js models >/dev/null && node ./scripts/verify-package-surface.mjs",
    "prepublishOnly": "npm run verify"
  },
  "bin": {
    "pi-cursor": "bin/pi-cursor.js"
  },
  "exports": {
    ".": {
      "import": "./pi-extension/cursor-acp/index.ts",
      "default": "./pi-extension/cursor-acp/index.ts"
    },
    "./extension": "./pi-extension/cursor-acp/index.ts",
    "./models": "./pi-extension/cursor-acp/models.json"
  },
  "pi": {
    "extensions": [
      "./pi-extension/cursor-acp/index.ts"
    ]
  },
  "files": [
    "bin",
    "dist",
    "install.sh",
    "pi-extension",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs/header.png",
    "docs/PUBLISHING.md"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xycld/pi-cursor.git"
  },
  "homepage": "https://github.com/xycld/pi-cursor#readme",
  "bugs": {
    "url": "https://github.com/xycld/pi-cursor/issues"
  },
  "keywords": [
    "pi",
    "cursor",
    "cursor-agent",
    "ai",
    "extension"
  ],
  "author": "xycld"
}
